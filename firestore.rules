rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Messages collection: anyone can send (create) a message
    // but only authenticated users (admin) can read or modify them.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // All other collections (projects, skills, experience, etc.)
    // Anyone can read (for the portfolio site)
    // Only authenticated users (admin) can create, update, or delete
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
